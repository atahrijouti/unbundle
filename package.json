{
  "name": "unbundle",
  "version": "0.0.4",
  "type": "module",
  "private": true,
  "description": "I don't like bundling",
  "scripts": {
    "build": "esbuild lib/client/index.ts --bundle --outfile=dist/client/index.js --format=esm",
    "postinstall": "pnpm run build"
  },
  "bin": {
    "unbundle-serve": "./lib/server/index.ts",
    "unbundle-build": "./lib/server/build.ts"
  },
  "exports": {
    ".": {
      "import": "./dist/client/index.js",
      "types": "./lib/client/index.ts"
    },
    "./eslint": {
      "import": "./eslint/unbundle.js",
      "types": "./eslint/unbundle.d.ts"
    }
  },
  "files": [
    "lib/",
    "LICENSE",
    "README.md"
  ],
  "dependencies": {
    "@eslint/js": "^9.23.0",
    "esbuild": "^0.25.2",
    "eslint": "^9.23.0",
    "globals": "^16.0.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.29.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/ws": "^8.18.1"
  }
}
